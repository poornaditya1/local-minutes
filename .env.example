# ==========================================
# Local Minutes macOS configuration
# ==========================================

# Server
LOCAL_MINUTES_HOST=127.0.0.1
LOCAL_MINUTES_PORT=8765

# Store meeting recordings, transcripts, notes, and metadata here.
# Leave this relative path for development, or replace with an absolute path.
LOCAL_MINUTES_DATA_DIR=./data

# macOS audio
# BlackHole and most meeting apps work best at 48000 Hz.
LOCAL_MINUTES_SAMPLE_RATE=48000

# Whisper transcription
# Use cpu/int8 for maximum compatibility.
# On Apple Silicon, you can later try faster options, but start here.
LOCAL_MINUTES_WHISPER_DEVICE=cpu
LOCAL_MINUTES_WHISPER_COMPUTE=int8

# Recommended Whisper model in the app UI:
# tiny   = fastest, lower accuracy
# base   = fast testing
# small  = recommended default
# medium = better accuracy, slower
LOCAL_MINUTES_WHISPER_MODEL=small

# LM Studio
LOCAL_MINUTES_LMSTUDIO_BASE_URL=http://localhost:1234/v1
LOCAL_MINUTES_LMSTUDIO_MODEL=google/gemma-4-26b-a4b-qat

# Keep Gemma from thinking forever or generating huge reasoning output.
LOCAL_MINUTES_LMSTUDIO_MAX_TOKENS=1200
LOCAL_MINUTES_LMSTUDIO_CHUNK_MAX_TOKENS=700
LOCAL_MINUTES_LMSTUDIO_TIMEOUT_SECONDS=300

# Transcript cleanup
# Removes near-duplicate mic/system lines caused by BlackHole echo or routing overlap.
LOCAL_MINUTES_DEDUP_TRANSCRIPT=1

# For duplicate lines, prefer the system track because it usually represents meeting audio.
# Use mic only if you want to prioritize your microphone track.
LOCAL_MINUTES_DEDUP_PREFER=system

# Optional tuning
LOCAL_MINUTES_DEDUP_TIME_WINDOW_SECONDS=2.5
LOCAL_MINUTES_DEDUP_SIMILARITY=0.86
